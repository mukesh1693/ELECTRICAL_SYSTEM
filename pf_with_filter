<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>MEP Pro: Power Quality & Capacity Architect</title>
    <style>
        :root {
            --bg: #0b0f1a; --panel: #161b2c; --kw: #00ff88; --kvar: #ffcc00; --kva: #00d9ff; --thd: #ff4d4d;
            --std: #22c55e; --detuned: #0ea5e9; --ahf: #a855f7; --led-off: #2d3748;
        }
        * { box-sizing: border-box; }
        body { background: var(--bg); color: #e2e8f0; font-family: 'Inter', system-ui, sans-serif; padding: 20px; display: flex; justify-content: center; line-height: 1.5; margin: 0;}
        .wrapper { max-width: 1200px; width: 100%; background: var(--panel); padding: 35px; border-radius: 20px; border: 1px solid #2d3748; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5); }
        
        /* Typography & Header */
        h1 { margin: 0; font-size: 28px; background: linear-gradient(90deg, #fff, #94a3b8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; text-transform: uppercase; letter-spacing: 1px; text-align: center;}
        .header-sub { display: flex; justify-content: center; flex-wrap: wrap; gap: 10px 20px; margin-top: 10px; font-size: 12px; font-weight: 700; color: #64748b; letter-spacing: 0.5px; text-align: center;}

        /* Solution Navigation */
        .solution-nav { display: flex; gap: 12px; margin: 30px 0; background: rgba(0,0,0,0.3); padding: 8px; border-radius: 12px; }
        .mode-btn { flex: 1; padding: 15px; border: none; border-radius: 10px; cursor: pointer; background: transparent; color: #94a3b8; font-weight: 700; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); font-size: 13px; text-transform: uppercase; letter-spacing: 1px; }
        .mode-btn.active { background: #1e293b; color: #fff; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3); }
        .mode-btn.active.std { border-bottom: 4px solid var(--std); }
        .mode-btn.active.det { border-bottom: 4px solid var(--detuned); }
        .mode-btn.active.ahf { border-bottom: 4px solid var(--ahf); }

        /* Status Panels */
        .stat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; margin-bottom: 25px; }
        .stat-box { background: rgba(0,0,0,0.4); padding: 20px; border-radius: 12px; text-align: center; border: 1px solid #2d3748; position: relative; overflow: hidden; transition: all 0.3s ease;}
        .stat-box::after { content: ''; position: absolute; bottom: 0; left: 0; height: 4px; width: 100%; background: var(--kva); opacity: 0.3; }
        .stat-box small { color: #94a3b8; font-size: 11px; font-weight: 800; text-transform: uppercase; display: block; margin-bottom: 8px; letter-spacing: 0.5px;}
        .stat-box strong { font-size: 28px; color: #f8fafc; font-variant-numeric: tabular-nums; transition: all 0.3s ease;}

        /* Main Visual Workspace */
        .viz-grid { display: grid; grid-template-columns: 1.2fr 0.8fr 1fr; gap: 20px; margin-bottom: 25px; }
        .card { background: rgba(0,0,0,0.2); padding: 25px; border-radius: 16px; border: 1px solid #2d3748; min-height: 400px; display: flex; flex-direction: column; position: relative; justify-content: flex-start;}
        .card-header { font-size: 11px; font-weight: 900; color: #64748b; text-transform: uppercase; margin-bottom: 20px; border-left: 3px solid #3b82f6; padding-left: 10px; letter-spacing: 1px; width: 100%;}
        .svg-container { flex-grow: 1; display: flex; justify-content: center; align-items: center; width: 100%; }

        /* Controls */
        .footer-controls { background: #0f172a; padding: 30px; border-radius: 16px; border: 1px solid #2d3748; display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
        .control-group label { display: flex; justify-content: space-between; font-weight: 700; color: #cbd5e1; margin-bottom: 15px; font-size: 14px; }
        input[type=range] { width: 100%; height: 6px; background: #1e293b; border-radius: 5px; appearance: none; cursor: pointer; }
        input[type=range]::-webkit-slider-thumb { appearance: none; width: 18px; height: 18px; background: #3b82f6; border-radius: 50%; border: 3px solid #fff; transition: 0.2s;}

        /* Equipment LEDs */
        .step { display: flex; align-items: center; justify-content: space-between; background: #1e293b; padding: 10px 15px; border-radius: 8px; margin-bottom: 8px; font-size: 13px; font-weight: 600; border: 1px solid #334155;}
        .led { width: 12px; height: 12px; border-radius: 50%; background: var(--led-off); transition: 0.4s; }
        .led.active.std { background: var(--std); box-shadow: 0 0 12px var(--std); }
        .led.active.det { background: var(--detuned); box-shadow: 0 0 12px var(--detuned); }
        .led.active.ahf { background: var(--ahf); box-shadow: 0 0 12px var(--ahf); }
        
        svg line, svg rect, svg path, svg text { transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); }

        /* =========================================
           RESPONSIVE VIEWPORT BREAKPOINTS (MOBILE)
           ========================================= */
        @media (max-width: 992px) {
            .viz-grid { grid-template-columns: 1fr; }
            .card { min-height: 350px; }
            .solution-nav { flex-direction: column; }
            .footer-controls { gap: 30px; }
        }

        @media (max-width: 650px) {
            body { padding: 10px; }
            .wrapper { padding: 20px; border-radius: 12px; }
            h1 { font-size: 22px; }
            .stat-grid { grid-template-columns: repeat(2, 1fr); }
            .footer-controls { grid-template-columns: 1fr; gap: 20px; padding: 20px; }
            .card { padding: 15px; }
        }
    </style>
</head>
<body>

<div class="wrapper">
    <div style="text-align: center;">
        <h1>Power Quality & Capacity Architect</h1>
        <div class="header-sub">
            <span>CEA REGULATIONS COMPLIANT</span>
            <span>•</span>
            <span>IEEE 519 HARMONIC LIMITS</span>
        </div>
    </div>

    <div class="solution-nav">
        <button class="mode-btn active std" onclick="updateMode(0, this)">Standard APFC</button>
        <button class="mode-btn det" onclick="updateMode(1, this)">Detuned Reactor (7%)</button>
        <button class="mode-btn ahf" onclick="updateMode(2, this)">Active Harmonic Filter (AHF)</button>
    </div>

    <div class="stat-grid">
        <div class="stat-box"><small>System Load (True kVA)</small><strong id="out-s-true">0.0</strong></div>
        <div class="stat-box"><small>Displacement PF (cos φ)</small><strong id="out-disp-pf" style="color:var(--kva)">0.00</strong></div>
        <div class="stat-box"><small>System THD (%)</small><strong id="out-thd" style="color:var(--thd)">0%</strong></div>
        <div class="stat-box" style="border-bottom: 4px solid var(--kva);"><small>True Power Factor</small><strong id="out-true-pf">0.000</strong></div>
    </div>

    <div class="viz-grid">
        <div class="card">
            <span class="card-header">Power Vector Triangle ($P, Q, D$)</span>
            <div class="svg-container">
                <svg viewBox="0 -30 250 340" style="width:100%; max-height:300px;">
                    <line x1="40" y1="280" x2="180" y2="280" stroke="var(--kw)" stroke-width="6" stroke-linecap="round"/>
                    <text x="110" y="305" fill="var(--kw)" font-size="12" font-weight="900" text-anchor="middle">100 kW</text>
                    <line id="vec-q" x1="180" y1="280" x2="180" y2="180" stroke="var(--kvar)" stroke-width="4" stroke-dasharray="5"/>
                    <line id="vec-d" x1="180" y1="180" x2="180" y2="100" stroke="var(--thd)" stroke-width="5" stroke-linecap="round"/>
                    <line id="hyp-disp" x1="40" y1="280" x2="180" y2="180" stroke="var(--kva)" stroke-width="1.5" stroke-dasharray="3" opacity="0.5"/>
                    <line id="hyp-true" x1="40" y1="280" x2="180" y2="100" stroke="#fff" stroke-width="3" stroke-linecap="round"/>
                    <text id="tag-q" x="190" y="230" fill="var(--kvar)" font-size="10" font-weight="700">Q (VAR)</text>
                    <text id="tag-d" x="190" y="140" fill="var(--thd)" font-size="10" font-weight="700">D (THD)</text>
                    <text id="tag-s" x="50" y="170" fill="#fff" font-size="13" font-weight="900">True kVA</text>
                </svg>
            </div>
        </div>

        <div class="card" style="align-items: center;">
            <span class="card-header">Capacity Analogy</span>
            <div class="svg-container">
                <svg viewBox="0 0 120 280" style="max-height: 280px; width: 100%;">
                    <rect x="30" y="40" width="60" height="210" rx="5" fill="rgba(255,255,255,0.02)" stroke="#475569" stroke-width="3"/>
                    <rect x="33" y="150" width="54" height="97" fill="#facc15" opacity="0.95"/>
                    <rect id="mug-foam" x="33" y="90" width="54" height="60" fill="#f8fafc"/>
                    
                    <text x="60" y="210" fill="#000" font-size="10" font-weight="900" text-anchor="middle">100 kW</text>
                    <text id="mug-waste-text" x="60" y="125" fill="#1e293b" font-size="11" font-weight="900" text-anchor="middle">WASTE</text>
                </svg>
            </div>
        </div>

        <div class="card">
            <span class="card-header">System Health & Mitigation</span>
            <div id="led-bay">
                <div class="step"><span id="lbl-step1">Bank Step 1 (25kVAr)</span><div id="led-1" class="led"></div></div>
                <div class="step"><span id="lbl-step2">Bank Step 2 (25kVAr)</span><div id="led-2" class="led"></div></div>
                <div class="step"><span id="lbl-step3">Bank Step 3 (25kVAr)</span><div id="led-3" class="led"></div></div>
            </div>
            <div class="svg-container" style="margin-top:15px; border-top:1px solid #2d3748; padding-top:10px;">
                <svg viewBox="0 0 200 100" style="width:100%; max-height: 120px;">
                    <line x1="0" y1="50" x2="200" y2="50" stroke="#334155" stroke-dasharray="2"/>
                    <path id="path-current" d="" fill="none" stroke-width="2.5" stroke-linecap="round"/>
                </svg>
            </div>
            <div id="status-alert" style="text-align:center; padding:12px; border-radius:8px; font-size:11px; font-weight:900; letter-spacing:1px; margin-top:10px; width: 100%;">NOMINAL</div>
        </div>
    </div>

    <div class="footer-controls">
        <div class="control-group">
            <label>Load Displacement PF (Lag) <span id="val-pf" style="color:var(--kva); font-size: 16px;">0.80</span></label>
            <input type="range" id="in-pf" min="0.50" max="1.0" step="0.01" value="0.80">
        </div>
        <div class="control-group">
            <label>Load Harmonic Distortion (THD) <span id="val-thd" style="color:var(--thd); font-size: 16px;">15%</span></label>
            <input type="range" id="in-thd" min="0" max="60" step="1" value="15">
        </div>
    </div>
</div>

<script>
    let activeMode = 0;
    const inPf = document.getElementById('in-pf');
    const inThd = document.getElementById('in-thd');

    function updateMode(m, btn) {
        activeMode = m;
        document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        
        const isAhf = (m === 2);
        document.getElementById('lbl-step1').textContent = isAhf ? "AHF DSP Module 1" : "Bank Step 1 (25kVAr)";
        document.getElementById('lbl-step2').textContent = isAhf ? "AHF DSP Module 2" : "Bank Step 2 (25kVAr)";
        document.getElementById('lbl-step3').textContent = isAhf ? "AHF DSP Module 3" : "Bank Step 3 (25kVAr)";
        
        calculate();
    }

    function calculate() {
        const rawPf = parseFloat(inPf.value);
        const loadThdPct = parseFloat(inThd.value);
        const kW = 100;
        
        let targetThdDec = loadThdPct / 100;
        let modeClass = 'std';
        let statusMsg = "SYSTEM NOMINAL";
        let statusColor = "rgba(34, 197, 94, 0.15)";
        let accentColor = "var(--std)";

        const Q_load = kW * Math.tan(Math.acos(rawPf));
        let Q_bank = 0; let Q_net = 0;

        if (activeMode === 0) { 
            Q_bank = (Q_load > 70) ? 75 : (Q_load > 45) ? 50 : (Q_load > 20) ? 25 : 0;
            Q_net = Math.max(0, Q_load - Q_bank);
            if (loadThdPct > 15) {
                statusMsg = "WARNING: CAPACITOR RESONANCE RISK";
                statusColor = "rgba(239, 68, 68, 0.15)";
                accentColor = "var(--thd)";
            }
        } 
        else if (activeMode === 1) { 
            modeClass = 'det';
            statusMsg = "SAFE: DETUNED REACTOR ENGAGED";
            statusColor = "rgba(14, 165, 233, 0.15)";
            accentColor = "var(--detuned)";
            Q_bank = (Q_load > 70) ? 75 : (Q_load > 45) ? 50 : (Q_load > 20) ? 25 : 0;
            Q_net = Math.max(0, Q_load - Q_bank);
            targetThdDec = targetThdDec * 0.92; 
        } 
        else if (activeMode === 2) { 
            modeClass = 'ahf';
            statusMsg = "PREMIUM: AHF DYNAMIC CORRECTION";
            statusColor = "rgba(168, 85, 247, 0.15)";
            accentColor = "var(--ahf)";
            Q_bank = Q_load; 
            Q_net = 0; 
            targetThdDec = targetThdDec * 0.05; 
        }

        const S_disp = Math.sqrt(Math.pow(kW, 2) + Math.pow(Q_net, 2));
        const disp_pf = kW / S_disp;
        const D = S_disp * targetThdDec;
        const S_true = Math.sqrt(Math.pow(kW, 2) + Math.pow(Q_net, 2) + Math.pow(D, 2));
        const true_pf = kW / S_true;

        document.getElementById('out-s-true').textContent = S_true.toFixed(1);
        document.getElementById('out-disp-pf').textContent = disp_pf.toFixed(2);
        document.getElementById('out-thd').textContent = (targetThdDec * 100).toFixed(0) + "%";
        document.getElementById('out-true-pf').textContent = true_pf.toFixed(3);
        document.getElementById('val-pf').textContent = rawPf.toFixed(2);
        document.getElementById('val-thd').textContent = loadThdPct + "%";

        const scale = 0.9;
        const yBase = 280;
        const yQ = yBase - (Q_net * scale);
        const yD = yQ - (D * scale);

        document.getElementById('vec-q').setAttribute('y1', yBase);
        document.getElementById('vec-q').setAttribute('y2', yQ);
        document.getElementById('hyp-disp').setAttribute('y2', yQ);
        document.getElementById('vec-d').setAttribute('y1', yQ);
        document.getElementById('vec-d').setAttribute('y2', yD);
        document.getElementById('hyp-true').setAttribute('y2', yD);
        
        document.getElementById('tag-q').setAttribute('y', yBase - (Q_net*scale/2) + 4);
        document.getElementById('tag-q').style.opacity = Q_net > 15 ? 1 : 0;
        document.getElementById('tag-d').setAttribute('y', yQ - (D*scale/2) + 4);
        document.getElementById('tag-d').style.opacity = D > 15 ? 1 : 0;
        document.getElementById('tag-s').setAttribute('y', yD - 12);

        // --- THE MUG FIX ---
        // Glass starts at y=40, Liquid starts at y=150.
        // Maximum internal height for foam is 150 - 40 - 2(margin) = 108.
        const wasteMag = Math.sqrt(Q_net*Q_net + D*D);
        const maxFoamH = 108; 
        const rawFoamH = wasteMag * 0.55; 
        const foamH = Math.min(maxFoamH, Math.max(2, rawFoamH));
        
        const foam = document.getElementById('mug-foam');
        foam.setAttribute('height', foamH);
        foam.setAttribute('y', 150 - foamH);
        
        const wasteTxt = document.getElementById('mug-waste-text');
        wasteTxt.setAttribute('y', 150 - (foamH/2) + 4);
        wasteTxt.textContent = Math.round(wasteMag) + " kVA";
        wasteTxt.style.opacity = foamH > 20 ? 1 : 0;

        for(let i=1; i<=3; i++){
            const led = document.getElementById('led-'+i);
            if (activeMode === 2) {
                led.className = (Q_load >= i*25) ? `led active ahf` : 'led';
            } else {
                led.className = (Q_bank >= i*25) ? `led active ${modeClass}` : 'led';
            }
        }

        let path = "M ";
        const phi = Math.acos(disp_pf); 
        for(let x=0; x<=200; x++) {
            const angle = (x/100) * Math.PI * 2;
            let y = 35 * Math.sin(angle - phi);
            if (targetThdDec > 0.04) {
                y += (targetThdDec * 25) * Math.sin(5 * (angle - phi));
                y += (targetThdDec * 10) * Math.sin(7 * (angle - phi));
            }
            path += `${x} ${50 - y} `;
        }
        const wPath = document.getElementById('path-current');
        wPath.setAttribute('d', path);
        wPath.style.stroke = `var(--${modeClass === 'std' ? 'kva' : modeClass})`;

        const alert = document.getElementById('status-alert');
        alert.textContent = statusMsg;
        alert.style.color = accentColor;
        alert.style.background = statusColor;
        alert.style.border = `1px solid ${accentColor}`;
    }

    inPf.addEventListener('input', calculate);
    inThd.addEventListener('input', calculate);
    calculate();
</script>
</body>
</html>
